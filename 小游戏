# 按钮类
# ============================================================
class Button:
    def __init__(self, x, y, width, height, text, color=COLOR_BUTTON,
                 hover_color=COLOR_BUTTON_HOVER, text_color=COLOR_WHITE,
                 font=None):
        self.rect = pygame.Rect(x, y, width, height)
        self.text = text
        self.color = color
        self.hover_color = hover_color
        self.text_color = text_color
        self.font = font or FONT_MEDIUM
        self.hovered = False
        self.enabled = True

    def update(self, mouse_pos):
        self.hovered = self.rect.collidepoint(mouse_pos) and self.enabled

    def is_clicked(self, mouse_pos, mouse_clicked):
        return self.hovered and mouse_clicked and self.enabled

    def draw(self, screen, color_override=None):
        bg = color_override if color_override else (
            self.hover_color if self.hovered else self.color)
        if not self.enabled:
            bg = (40, 45, 55)
        pygame.draw.rect(screen, bg, self.rect, border_radius=8)
        pygame.draw.rect(screen, (100, 110, 130), self.rect, 2, border_radius=8)
        txt = self.font.render(self.text, True, self.text_color if self.enabled else (120, 120, 120))
        txt_rect = txt.get_rect(center=self.rect.center)
        screen.blit(txt, txt_rect)


