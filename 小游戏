# 精灵缓存和缩放
# ============================================================
SCALED_SPRITES = {}

def get_scaled_sprite(name, target_size):
    """获取指定大小的缩放精灵，带缓存"""
    key = (name, target_size)
    if key in SCALED_SPRITES:
        return SCALED_SPRITES[key]
    sprite = ASSETS.get_sprite(name)
    if sprite is None:
        return None
    orig_w, orig_h = sprite.get_size()
    # 保持宽高比缩放
    scale = target_size / max(orig_w, orig_h)
    new_w = max(1, int(orig_w * scale))
    new_h = max(1, int(orig_h * scale))
    scaled = pygame.transform.smoothscale(sprite, (new_w, new_h))
    SCALED_SPRITES[key] = scaled
    return scaled


def get_enemy_sprite(enemy_type, size=36):
    """获取敌人精灵"""
    sprite_index = {"normal": 0, "fast": 1, "tank": 2, "boss": 3}
    idx = sprite_index.get(enemy_type, 0)
    return get_scaled_sprite(f"enemy_{idx}", size)


def get_tower_sprite(tower_type, level, size=38):
    """获取防御塔精灵"""
    sprite = get_scaled_sprite(f"tower_{tower_type}", size + level * 4)
    return sprite


