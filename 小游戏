# 地图背景渲染
# ============================================================
class MapRenderer:
    """预渲染地图背景纹理"""
    def __init__(self):
        self.bg_surface = None
        self._needs_rebuild = True

    def build(self):
        if not self._needs_rebuild:
            return self.bg_surface

        self.bg_surface = pygame.Surface((MAP_WIDTH, MAP_HEIGHT))

        # 纯色背景
        self.bg_surface.fill(COLOR_BG)

        # ======== 绘制路径 —— 简洁线条 ========
        # 连续路径线
        for i in range(len(PATH_POINTS) - 1):
            px1, py1 = grid_to_pixel(*PATH_POINTS[i])
            px2, py2 = grid_to_pixel(*PATH_POINTS[i + 1])
            pygame.draw.line(self.bg_surface, (180, 170, 150),
                             (px1, py1), (px2, py2), 20)

        # 小方向箭头
        for i in range(len(PATH_POINTS) - 1):
            x1, y1 = PATH_POINTS[i]
            x2, y2 = PATH_POINTS[i + 1]
            px1, py1 = grid_to_pixel(x1, y1)
            px2, py2 = grid_to_pixel(x2, y2)
            mid_x, mid_y = (px1 + px2) // 2, (py1 + py2) // 2
            dx, dy = px2 - px1, py2 - py1
            dist = math.sqrt(dx*dx + dy*dy)
            if dist > 0:
                ux, uy = dx / dist, dy / dist
                tip = (mid_x + ux * 6, mid_y + uy * 6)
                left = (mid_x - ux * 4 - uy * 5, mid_y - uy * 4 + ux * 5)
                right = (mid_x - ux * 4 + uy * 5, mid_y - uy * 4 - ux * 5)
                pygame.draw.polygon(self.bg_surface, (120, 110, 100),
                                    [tip, left, right])

        # 起点 "S"
        sx, sy = grid_to_pixel(*PATH_POINTS[0])
        font_small = pygame.font.SysFont("simhei", 16, bold=True)
        label = font_small.render("起点", True, (0, 130, 0))
        self.bg_surface.blit(label, (sx - 16, sy - 24))

        # 终点 "E"
        ex, ey = grid_to_pixel(*PATH_POINTS[-1])
        label = font_small.render("终点", True, (200, 30, 30))
        self.bg_surface.blit(label, (ex - 16, ey - 24))

        self._needs_rebuild = False
        return self.bg_surface


MAP_RENDERER = MapRenderer()


