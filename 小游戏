class Enemy:
    ENEMY_TYPES = {
        "normal": {"name": "普通怪", "hp": 100, "speed": 1.5, "reward": 15, "color": COLOR_RED, "size": 12},
        "fast": {"name": "快速怪", "hp": 60, "speed": 3.0, "reward": 20, "color": (255, 200, 50), "size": 10},
        "tank": {"name": "坦克怪", "hp": 300, "speed": 1.0, "reward": 30, "color": (100, 100, 100), "size": 16},
        "boss": {"name": "BOSS", "hp": 1000, "speed": 0.8, "reward": 100, "color": (200, 50, 200), "size": 20},
    }

    def __init__(self, enemy_type, hp_multiplier=1.0):
        info = self.ENEMY_TYPES[enemy_type]
        self.type = enemy_type
        self.name = info["name"]
        self.max_hp = int(info["hp"] * hp_multiplier)
        self.hp = self.max_hp
        self.base_speed = info["speed"]
        self.speed = self.base_speed
        self.reward = info["reward"]
        self.color = info["color"]
        self.base_size = info["size"]

        self.alive = True
        self.reached_end = False
        self.path_index = 0
        self.path_progress = 0.0
        self.x, self.y = grid_to_pixel(*PATH_POINTS[0])
        self.slow_timer = 0
        self.slow_factor = 1.0

        # 动画
        self.anim_frame = 0
        self.anim_timer = 0
        self.facing_right = True
        self.bob_offset = random.uniform(0, 2 * math.pi)

    def slow(self, factor, duration):
        if factor < self.slow_factor:
            self.slow_factor = factor
            self.slow_timer = duration
            self.speed = self.base_speed * self.slow_factor

    def update(self):
        if not self.alive:
            return False

        if self.slow_timer > 0:
            self.slow_timer -= 1
            self.speed = self.base_speed * self.slow_factor
            if self.slow_timer == 0:
                self.speed = self.base_speed
                self.slow_factor = 1.0

        if self.path_index >= len(PATH_POINTS) - 1:
            self.reached_end = True
            self.alive = False
            return True

        tx, ty = grid_to_pixel(*PATH_POINTS[self.path_index + 1])
        dx, dy = tx - self.x, ty - self.y
        dist = math.sqrt(dx * dx + dy * dy)

        if dist < self.speed + 1:
            self.path_index += 1
            self.x, self.y = tx, ty
            self.path_progress = self.path_index
        else:
            self.x += (dx / dist) * self.speed
            self.y += (dy / dist) * self.speed
            # 朝向
            if dx > 0:
                self.facing_right = True
            elif dx < 0:
                self.facing_right = False
            # 路径进度
            segment_start = self.path_index
            sx, sy = grid_to_pixel(*PATH_POINTS[segment_start])
            ex, ey = grid_to_pixel(*PATH_POINTS[segment_start + 1])
            seg_total = distance((sx, sy), (ex, ey))
            seg_done = seg_total - dist
            self.path_progress = segment_start + seg_done / max(seg_total, 1)

        # 行走动画
        self.anim_timer += 1
        self.bob_offset += 0.15
        if self.anim_timer > 8:
            self.anim_timer = 0
            self.anim_frame = (self.anim_frame + 1) % 4

        return False

    def take_damage(self, damage):
        self.hp -= damage
        if self.hp <= 0:
            self.hp = 0
            self.alive = False
            SOUND_DEATH.play()
            return True
        return False

    def draw(self, screen):
        if not self.alive:
            return
        cx, cy = int(self.x), int(self.y)

        # 获取精灵图
        display_size = self.base_size * 2.5
        if self.type == "boss":
            display_size = self.base_size * 3.5
        sprite = get_enemy_sprite(self.type, size=int(display_size * 2.5))

        if sprite:
            # 翻转朝向
            if not self.facing_right:
                sprite = pygame.transform.flip(sprite, True, False)
            # 行走时上下晃动
            bob_y = math.sin(self.bob_offset) * 2
            sprite_rect = sprite.get_rect(center=(cx, cy + bob_y))
            screen.blit(sprite, sprite_rect)
        else:
            # 降级绘制
            pygame.draw.circle(screen, self.color, (cx, cy), self.base_size)
            pygame.draw.circle(screen, COLOR_BLACK, (cx, cy), self.base_size, 2)

        # 冰霜效果
        if self.slow_timer > 0 and self.slow_factor < 0.7:
            ice_overlay = pygame.Surface((self.base_size * 3, self.base_size * 3), pygame.SRCALPHA)
            pygame.draw.circle(ice_overlay, (100, 200, 255, 100),
                               (self.base_size * 1.5, self.base_size * 1.5), self.base_size)
            screen.blit(ice_overlay, (cx - self.base_size * 1.5, cy - self.base_size * 1.5))

        # 血条
        bar_width = self.base_size * 2 + 10
        bar_height = 5
        bar_x = cx - bar_width // 2
        bar_y = cy - self.base_size - 12
        hp_ratio = self.hp / self.max_hp
        pygame.draw.rect(screen, (40, 10, 10), (bar_x, bar_y, bar_width, bar_height))
        hp_color = COLOR_GREEN if hp_ratio > 0.5 else (COLOR_ORANGE if hp_ratio > 0.25 else COLOR_RED)
        pygame.draw.rect(screen, hp_color,
                         (bar_x, bar_y, int(bar_width * hp_ratio), bar_height))
        pygame.draw.rect(screen, COLOR_BLACK, (bar_x, bar_y, bar_width, bar_height), 1)


