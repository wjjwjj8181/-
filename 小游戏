                f"伤害: {t.damage}",
                f"射程: {t.range}",
                f"攻速: {t.cooldown}帧",
            ]
            for i, line in enumerate(info_lines):
                txt = FONT_SMALL.render(line, True, COLOR_WHITE)
                self.screen.blit(txt, (panel_x + 10, y_info + 50 + i * 22))
