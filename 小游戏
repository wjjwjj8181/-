            if t.level < t.max_level:
                self.upgrade_btn.text = f"升级 ¥{upgrade_cost}"
            else:
                self.upgrade_btn.text = "已满级"
            self.upgrade_btn.draw(self.screen)
            self.sell_btn.draw(self.screen)
        elif self.selected_tower_type:
            info = Tower.TOWER_TYPES[self.selected_tower_type]
            sprite = get_tower_sprite(self.selected_tower_type, 1, size=50)
            if sprite:
                self.screen.blit(sprite, sprite.get_rect(center=(panel_x + PANEL_WIDTH // 2, y_info + 25)))
            txt = FONT_SMALL.render(f"已选择: {info['name']}", True, COLOR_WHITE)
            self.screen.blit(txt, (panel_x + 10, y_info + 55))
            txt = FONT_SMALL.render("点击地图放置", True, (180, 180, 180))
            self.screen.blit(txt, (panel_x + 10, y_info + 77))
        if self.state in ("game_over", "victory"):
            self.restart_btn.draw(self.screen)

    def draw_gameplay(self):
        self.draw_map()
        if self.show_range and self.selected_tower:
            self.selected_tower.draw_range(self.screen)
        if self.selected_tower_type and self.mouse_pos[0] < MAP_WIDTH:
            col, row = pixel_to_grid(*self.mouse_pos)
            if col is not None and row is not None and not is_on_path(col, row):
                info = Tower.TOWER_TYPES[self.selected_tower_type]
                cx, cy = grid_to_pixel(col, row)
                surface = pygame.Surface((info["range"] * 2, info["range"] * 2), pygame.SRCALPHA)
                pygame.draw.circle(surface, (*info["color"], 25),
                                   (info["range"], info["range"]), info["range"])
                self.screen.blit(surface, (cx - info["range"], cy - info["range"]))
                sprite = get_tower_sprite(self.selected_tower_type, 1, size=32)
                if sprite:
                    s = pygame.Surface(sprite.get_size(), pygame.SRCALPHA)
                    s.blit(sprite, (0, 0))
                    s.set_alpha(150)
                    self.screen.blit(s, sprite.get_rect(center=(cx, cy)))
        for tower in self.towers:
            tower.draw(self.screen)
        for enemy in self.enemies:
            enemy.draw(self.screen)
        for proj in self.projectiles:
            proj.draw(self.screen)
        for p in self.particles:
            alpha = int(255 * p["life"] / p["max_life"])
            color = (*p["color"], alpha)
            glow = pygame.Surface((p["size"] * 3, p["size"] * 3), pygame.SRCALPHA)
            pygame.draw.circle(glow, color, (p["size"] * 1.5, p["size"] * 1.5), p["size"] * 1.5)
            self.screen.blit(glow, (int(p["x"] - p["size"] * 1.5),
                                    int(p["y"] - p["size"] * 1.5)))
        pygame.draw.rect(self.screen, COLOR_WHITE, (0, 0, MAP_WIDTH, MAP_HEIGHT), 2)
        self.draw_panel()

    def draw_menu(self):
        self.screen.fill(COLOR_BG)
        # 草地背景装饰
        grass = ASSETS.get_texture("grass")
        if grass:
            for y in range(0, WINDOW_HEIGHT, grass.get_height()):
                for x in range(0, MAP_WIDTH, grass.get_width()):
                    self.screen.blit(grass, (x, y))
        title = FONT_TITLE.render("塔 防 游 戏", True, COLOR_GOLD)
        title_rect = title.get_rect(center=(WINDOW_WIDTH // 2, 120))
        self.screen.blit(title, title_rect)
        subtitle = FONT_LARGE.render("Tower Defense", True, COLOR_WHITE)
        sub_rect = subtitle.get_rect(center=(WINDOW_WIDTH // 2, 180))
        self.screen.blit(subtitle, sub_rect)
        # 显示敌人和塔的精灵图示例
        enemy_names = [("normal", "普通怪"), ("fast", "快速怪"), ("tank", "坦克怪"), ("boss", "BOSS")]
        tower_types = [("archer", "箭塔"), ("cannon", "炮塔"), ("ice", "冰塔"), ("magic", "魔法塔")]
        y = 230
        x_offset = 200
        for i, (etype, ename) in enumerate(enemy_names):
            sprite = get_enemy_sprite(etype, size=30)
            if sprite:
                self.screen.blit(sprite, sprite.get_rect(center=(x_offset + i * 120, y)))
            txt = FONT_SMALL.render(ename, True, COLOR_WHITE)
            self.screen.blit(txt, (x_offset + i * 120 - 20, y + 20))
        y += 70
        for i, (ttype, tname) in enumerate(tower_types):
            sprite = get_tower_sprite(ttype, 1, size=30)
            if sprite:
                self.screen.blit(sprite, sprite.get_rect(center=(x_offset + i * 120, y)))
            txt = FONT_SMALL.render(tname, True, COLOR_WHITE)
            self.screen.blit(txt, (x_offset + i * 120 - 20, y + 20))
        y += 70
        ops = [
            "操作: 选择塔 → 点击地图放置 → 开始波次",
            "点击已放置的塔可升级或出售",
            "P 暂停 | ESC 退出",
        ]
        for op in ops:
            txt = FONT_SMALL.render(op, True, (180, 180, 180))
            self.screen.blit(txt, (250, y))
            y += 25
        start_btn = Button(WINDOW_WIDTH // 2 - 120, y + 30, 240, 60,
                           "开始游戏", color=(50, 150, 80),
                           hover_color=(70, 200, 100), font=FONT_TITLE)
        start_btn.update(self.mouse_pos)
        start_btn.draw(self.screen)
        self._start_btn = start_btn

    def draw_game_over(self):
        overlay = pygame.Surface((WINDOW_WIDTH, WINDOW_HEIGHT), pygame.SRCALPHA)
        overlay.fill((0, 0, 0, 180))
        self.screen.blit(overlay, (0, 0))
        if self.state == "game_over":
            title = FONT_TITLE.render("游 戏 结 束", True, COLOR_RED)
        else:
            title = FONT_TITLE.render("胜 利 !", True, COLOR_GOLD)
        title_rect = title.get_rect(center=(WINDOW_WIDTH // 2, WINDOW_HEIGHT // 2 - 50))
        self.screen.blit(title, title_rect)
        score_txt = FONT_LARGE.render(f"最终得分: {self.score}", True, COLOR_WHITE)
        score_rect = score_txt.get_rect(center=(WINDOW_WIDTH // 2, WINDOW_HEIGHT // 2 + 10))
        self.screen.blit(score_txt, score_rect)
        wave_txt = FONT_MEDIUM.render(f"到达波次: {self.wave}", True, COLOR_WHITE)
        wave_rect = wave_txt.get_rect(center=(WINDOW_WIDTH // 2, WINDOW_HEIGHT // 2 + 45))
        self.screen.blit(wave_txt, wave_rect)
        self.restart_btn.draw(self.screen)

    def draw_pause_overlay(self):
        overlay = pygame.Surface((WINDOW_WIDTH, WINDOW_HEIGHT), pygame.SRCALPHA)
        overlay.fill((0, 0, 0, 150))
        self.screen.blit(overlay, (0, 0))
        pause_txt = FONT_TITLE.render("暂 停", True, COLOR_WHITE)
        pause_rect = pause_txt.get_rect(center=(MAP_WIDTH // 2, MAP_HEIGHT // 2))
        self.screen.blit(pause_txt, pause_rect)
        tip_txt = FONT_MEDIUM.render("按 P 继续", True, COLOR_WHITE)
        tip_rect = tip_txt.get_rect(center=(MAP_WIDTH // 2, MAP_HEIGHT // 2 + 45))
        self.screen.blit(tip_txt, tip_rect)

    def run(self):
        while self.running:
            self.mouse_clicked = False
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    self.running = False
                    return
                if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:
                    self.mouse_clicked = True
                if event.type == pygame.KEYDOWN:
                    if event.key == pygame.K_ESCAPE:
                        self.running = False
                        return
                    if event.key == pygame.K_p:
                        if self.state == "playing":
                            self.state = "paused"
                        elif self.state == "paused":
                            self.state = "playing"
                    if event.key == pygame.K_SPACE and self.state == "playing":
                        self.start_new_wave()
            self.mouse_pos = pygame.mouse.get_pos()
            if self.state == "menu":
                self.draw_menu()
                if hasattr(self, '_start_btn'):
                    self._start_btn.update(self.mouse_pos)
                    if self._start_btn.hovered and self.mouse_clicked:
                        self.state = "playing"
            elif self.state == "playing":
                self.handle_click()
                self.update()
                self.draw_gameplay()
            elif self.state == "paused":
                self.draw_gameplay()
                self.draw_pause_overlay()
            elif self.state in ("game_over", "victory"):
                self.draw_gameplay()
                self.draw_game_over()
                if self.restart_btn.is_clicked(self.mouse_pos, self.mouse_clicked):
                    self.__init__()
            pygame.display.flip()
            self.clock.tick(FPS)
        pygame.quit()
        sys.exit()


