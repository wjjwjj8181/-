class Game:
    def __init__(self):
        self.screen = pygame.display.set_mode((WINDOW_WIDTH, WINDOW_HEIGHT))
        pygame.display.set_caption("塔防游戏 - Tower Defense")
        self.clock = pygame.time.Clock()
        self.running = True
        self.state = "menu"

        # 加载资源
        ASSETS.load_all()
        MAP_RENDERER._needs_rebuild = True

        # 游戏数据
        self.gold = 300
        self.lives = 20
        self.wave = 0
        self.max_waves = 15
        self.score = 0
        self.towers = []
        self.enemies = []
        self.projectiles = []
        self.selected_tower_type = None
        self.selected_tower = None
        self.show_range = False
        self.wave_active = False
        self.enemies_to_spawn = []
        self.spawn_timer = 0
        self.spawn_interval = 40
        self.mouse_pos = (0, 0)
        self.mouse_clicked = False
        self.particles = []
        self.init_ui()

    def init_ui(self):
        panel_x = MAP_WIDTH + 10
        self.tower_buttons = []
        types = [
            ("archer", COLOR_GREEN),
            ("cannon", COLOR_ORANGE),
            ("ice", COLOR_ICE),
            ("magic", COLOR_PURPLE),
        ]
        for i, (t_type, color) in enumerate(types):
            info = Tower.TOWER_TYPES[t_type]
            btn = Button(panel_x, 60 + i * 65, 200, 55,
                         f"{info['name']}  ¥{info['cost']}",
                         color=(50, 55, 65),
                         hover_color=(70, 80, 100),
                         font=FONT_MEDIUM)
            btn.tower_type = t_type
            self.tower_buttons.append(btn)

        self.start_wave_btn = Button(panel_x, 340, 200, 45, "▶ 开始波次",
                                     color=(50, 150, 80), hover_color=(70, 200, 100),
                                     font=FONT_LARGE)
        self.upgrade_btn = Button(panel_x, WINDOW_HEIGHT - 160, 200, 40,
                                  "升级", color=(100, 70, 200),
                                  hover_color=(130, 100, 230))
        self.sell_btn = Button(panel_x, WINDOW_HEIGHT - 110, 200, 40,
                               "出售", color=(200, 70, 70),
                               hover_color=(240, 100, 100))
        self.restart_btn = Button(panel_x, WINDOW_HEIGHT - 100, 200, 50,
                                  "重新开始", color=(50, 150, 80),
                                  hover_color=(70, 200, 100), font=FONT_LARGE)

    def add_particles(self, x, y, color, count=8):
        for _ in range(count):
            angle = random.uniform(0, 2 * math.pi)
            speed = random.uniform(2, 6)
            life = random.randint(10, 25)
            self.particles.append({
                "x": x, "y": y,
                "vx": math.cos(angle) * speed,
                "vy": math.sin(angle) * speed,
                "life": life, "max_life": life,
                "color": color, "size": random.randint(2, 5)
            })

    def spawn_enemy(self, enemy_type, hp_mult=1.0):
        self.enemies.append(Enemy(enemy_type, hp_mult))

    def generate_wave(self):
        self.wave += 1
        self.enemies_to_spawn.clear()
        hp_mult = 1.0 + (self.wave - 1) * 0.2

        if self.wave == 1:
            for _ in range(5): self.enemies_to_spawn.append(("normal", hp_mult))
        elif self.wave == 2:
            for _ in range(8): self.enemies_to_spawn.append(("normal", hp_mult))
            self.enemies_to_spawn.append(("fast", hp_mult))
        elif self.wave == 3:
            for _ in range(6): self.enemies_to_spawn.append(("fast", hp_mult))
            for _ in range(4): self.enemies_to_spawn.append(("normal", hp_mult))
        elif self.wave == 4:
            for _ in range(5): self.enemies_to_spawn.append(("tank", hp_mult))
            for _ in range(3): self.enemies_to_spawn.append(("normal", hp_mult))
        elif self.wave == 5:
            self.enemies_to_spawn.append(("boss", hp_mult * 1.5))
            for _ in range(5): self.enemies_to_spawn.append(("normal", hp_mult))
        else:
            count = 6 + self.wave
            if self.wave % 5 == 0:
                self.enemies_to_spawn.append(("boss", hp_mult * (1 + (self.wave // 5) * 0.5)))
            for _ in range(count):
                r = random.randint(1, 6)
                if r <= 3:
                    self.enemies_to_spawn.append(("normal", hp_mult))
                elif r <= 5:
                    self.enemies_to_spawn.append(("fast", hp_mult))
                else:
                    self.enemies_to_spawn.append(("tank", hp_mult))

        random.shuffle(self.enemies_to_spawn)
        self.spawn_timer = 60
        self.spawn_interval = max(15, 40 - self.wave)
        self.wave_active = True
        SOUND_WAVE_START.play()

    def start_new_wave(self):
        if self.wave_active or len(self.enemies) > 0:
            return
        if self.wave >= self.max_waves:
            return
        self.generate_wave()

    def place_tower(self, col, row, tower_type):
        if not tower_type:
            return False
        info = Tower.TOWER_TYPES[tower_type]
        if self.gold < info["cost"]:
            return False
        if is_on_path(col, row):
            return False
        for t in self.towers:
            if t.col == col and t.row == row:
                return False
        tower = Tower(col, row, tower_type)
        self.towers.append(tower)
        self.gold -= info["cost"]
        SOUND_PLACE_TOWER.play()
        self.add_particles(tower.x, tower.y, tower.color, 12)
        return True

    def upgrade_tower(self, tower):
        cost = tower.get_upgrade_cost()
        if self.gold < cost:
            return False
        if not tower.upgrade():
            return False
        self.gold -= cost
        SOUND_UPGRADE.play()
        self.add_particles(tower.x, tower.y, COLOR_GOLD, 15)
        return True

    def sell_tower(self, tower):
        value = tower.get_sell_value()
        self.gold += value
        self.towers.remove(tower)
        self.add_particles(tower.x, tower.y, COLOR_GOLD, 10)
        self.selected_tower = None

    def handle_click(self):
        mx, my = self.mouse_pos
        if self.start_wave_btn.is_clicked((mx, my), self.mouse_clicked):
            self.start_new_wave()
        if self.restart_btn.is_clicked((mx, my), self.mouse_clicked):
            self.__init__()
            return
        if self.selected_tower:
            if self.upgrade_btn.is_clicked((mx, my), self.mouse_clicked):
                self.upgrade_tower(self.selected_tower)
                return
            if self.sell_btn.is_clicked((mx, my), self.mouse_clicked):
                self.sell_tower(self.selected_tower)
                return
        for btn in self.tower_buttons:
            if btn.is_clicked((mx, my), self.mouse_clicked):
                info = Tower.TOWER_TYPES[btn.tower_type]
                if self.gold >= info["cost"]:
                    self.selected_tower_type = btn.tower_type
                    self.selected_tower = None
                    self.show_range = True
                return
        if mx < MAP_WIDTH:
            col, row = pixel_to_grid(mx, my)
            if col is not None and row is not None:
                clicked_tower = None
                for tower in self.towers:
                    if tower.col == col and tower.row == row:
                        clicked_tower = tower
                        break
                if clicked_tower:
                    self.selected_tower = clicked_tower
                    self.selected_tower_type = None
                    self.show_range = True
                elif self.selected_tower_type:
                    if self.place_tower(col, row, self.selected_tower_type):
                        self.selected_tower_type = None
                        self.show_range = False
                else:
                    self.selected_tower = None
                    self.selected_tower_type = None
                    self.show_range = False

    def update(self):
        if self.state != "playing":
            return
        for p in self.particles[:]:
            p["x"] += p["vx"]
            p["y"] += p["vy"]
            p["life"] -= 1
            if p["life"] <= 0:
                self.particles.remove(p)
        if self.wave_active and self.enemies_to_spawn:
            self.spawn_timer -= 1
            if self.spawn_timer <= 0:
                etype, hpm = self.enemies_to_spawn.pop(0)
                self.spawn_enemy(etype, hpm)
                self.spawn_timer = self.spawn_interval
        if self.wave_active and not self.enemies_to_spawn and not self.enemies:
            self.wave_active = False
            wave_bonus = 50 + self.wave * 10
            self.gold += wave_bonus
            if self.wave >= self.max_waves:
                self.state = "victory"
        for enemy in self.enemies[:]:
            reached = enemy.update()
            if reached:
                self.lives -= 1
                SOUND_ENEMY_REACH.play()
                self.add_particles(enemy.x, enemy.y, COLOR_RED, 15)
                if self.lives <= 0:
                    self.state = "game_over"
                    SOUND_GAME_OVER.play()
            elif not enemy.alive:
                self.gold += enemy.reward
                self.score += enemy.reward * 10
                self.add_particles(enemy.x, enemy.y, enemy.color, 10)
                self.enemies.remove(enemy)
        for tower in self.towers:
            tower.update(self.enemies)
            proj = tower.shoot()
            if proj:
                self.projectiles.append(proj)
                if tower.type == "archer": SOUND_SHOOT_ARROW.play()
                elif tower.type == "cannon": SOUND_SHOOT_CANNON.play()
                elif tower.type == "ice": SOUND_SHOOT_ICE.play()
                elif tower.type == "magic": SOUND_SHOOT_MAGIC.play()
        for tower in self.towers:
            if tower.type == "magic" and tower.target and tower.cooldown_timer == tower.cooldown - 1:
                for enemy in self.enemies:
                    if enemy.alive and distance((tower.x, tower.y), (enemy.x, enemy.y)) <= tower.range * 0.6:
                        enemy.take_damage(tower.damage // 3)
        for proj in self.projectiles[:]:
            proj.update()
            if not proj.alive:
                self.projectiles.remove(proj)
        for btn in self.tower_buttons:
            btn.enabled = (self.gold >= Tower.TOWER_TYPES[btn.tower_type]["cost"])
            btn.update(self.mouse_pos)
        self.start_wave_btn.enabled = (not self.wave_active and len(self.enemies) == 0)
        self.start_wave_btn.update(self.mouse_pos)
        if self.selected_tower:
            if self.selected_tower.level < self.selected_tower.max_level:
                self.upgrade_btn.enabled = self.gold >= self.selected_tower.get_upgrade_cost()
            else:
                self.upgrade_btn.enabled = False
                self.upgrade_btn.text = "已满级"
            self.sell_btn.text = f"出售 ¥{self.selected_tower.get_sell_value()}"
            self.sell_btn.enabled = True
            self.upgrade_btn.update(self.mouse_pos)
            self.sell_btn.update(self.mouse_pos)
        else:
            self.upgrade_btn.text = "升级"
            self.sell_btn.text = "出售"
        self.restart_btn.update(self.mouse_pos)

    def draw_map(self):
        bg = MAP_RENDERER.build()
        self.screen.blit(bg, (0, 0))
        # 网格线（半透明）
        for col in range(GRID_COLS):
