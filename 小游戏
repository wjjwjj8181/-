def grid_to_pixel(col, row):
    return col * GRID_SIZE + GRID_SIZE // 2, row * GRID_SIZE + GRID_SIZE // 2


def pixel_to_grid(x, y):
    col = x // GRID_SIZE
    row = y // GRID_SIZE
    if 0 <= col < GRID_COLS and 0 <= row < GRID_ROWS:
        return col, row
    return None, None


def is_on_path(col, row):
    for i in range(len(PATH_POINTS) - 1):
        x1, y1 = PATH_POINTS[i]
        x2, y2 = PATH_POINTS[i + 1]
        if x1 == x2:  # 垂直
            if col == x1 and min(y1, y2) <= row <= max(y1, y2):
                return True
        elif y1 == y2:  # 水平
            if row == y1 and min(x1, x2) <= col <= max(x1, x2):
                return True
    return False


def distance(p1, p2):
    return math.sqrt((p1[0] - p2[0]) ** 2 + (p1[1] - p2[1]) ** 2)


def get_path_rects():
    """返回所有路径格子坐标集合"""
    rects = set()
    for i in range(len(PATH_POINTS) - 1):
        x1, y1 = PATH_POINTS[i]
        x2, y2 = PATH_POINTS[i + 1]
        if x1 == x2:  # 垂直
            for y in range(min(y1, y2), max(y1, y2) + 1):
                rects.add((x1, y))
        else:  # 水平
            for x in range(min(x1, x2), max(x1, x2) + 1):
                rects.add((x, y1))
    return rects


PATH_CELLS = get_path_rects()


