class Tower:
    TOWER_TYPES = {
        "archer": {
            "name": "箭塔",
            "cost": 50, "range": 120, "damage": 15, "cooldown": 30,
            "color": COLOR_GREEN, "bullet_color": COLOR_GREEN,
            "bullet_speed": 10, "effect": "normal",
            "upgrade_cost": 40, "upgrade_damage": 10, "upgrade_range": 15,
            "level_name": {1: "箭塔", 2: "强弓塔", 3: "神射塔"}
        },
        "cannon": {
            "name": "炮塔",
            "cost": 100, "range": 100, "damage": 50, "cooldown": 50,
            "color": COLOR_ORANGE, "bullet_color": COLOR_ORANGE,
            "bullet_speed": 7, "effect": "cannon",
            "upgrade_cost": 80, "upgrade_damage": 25, "upgrade_range": 10,
            "level_name": {1: "炮塔", 2: "加农炮", 3: "毁灭者"}
        },
        "ice": {
            "name": "冰塔",
            "cost": 75, "range": 110, "damage": 8, "cooldown": 25,
            "color": COLOR_ICE, "bullet_color": COLOR_ICE,
            "bullet_speed": 9, "effect": "ice",
            "upgrade_cost": 60, "upgrade_damage": 5, "upgrade_range": 15,
            "level_name": {1: "冰塔", 2: "寒冰塔", 3: "极冻塔"}
        },
        "magic": {
            "name": "魔法塔",
            "cost": 150, "range": 140, "damage": 35, "cooldown": 40,
            "color": COLOR_PURPLE, "bullet_color": COLOR_PURPLE,
            "bullet_speed": 8, "effect": "magic",
            "upgrade_cost": 120, "upgrade_damage": 20, "upgrade_range": 20,
            "level_name": {1: "魔法塔", 2: "奥术塔", 3: "大法师塔"}
        }
    }

    def __init__(self, col, row, tower_type):
        self.col = col
        self.row = row
        self.x, self.y = grid_to_pixel(col, row)
        self.type = tower_type
        self.level = 1
        self.max_level = 3

        info = self.TOWER_TYPES[tower_type]
        self.name = info["name"]
        self.cost = info["cost"]
        self.range = info["range"]
        self.damage = info["damage"]
        self.cooldown = info["cooldown"]
        self.color = info["color"]
        self.bullet_color = info["bullet_color"]
        self.bullet_speed = info["bullet_speed"]
        self.effect = info["effect"]
        self.upgrade_cost = info["upgrade_cost"]
        self.upgrade_damage = info["upgrade_damage"]
        self.upgrade_range = info["upgrade_range"]
        self.level_name = info["level_name"]

        self.cooldown_timer = 0
        self.target = None
        self.angle = 0

        # 动画
        self.float_offset = random.uniform(0, 2 * math.pi)

    def get_upgrade_cost(self):
        return self.upgrade_cost * self.level

    def get_sell_value(self):
        total = self.cost
        for lv in range(2, self.level + 1):
            total += self.upgrade_cost * (lv - 1)
        return total // 2

    def upgrade(self):
        if self.level >= self.max_level:
            return False
        self.level += 1
        self.damage += self.upgrade_damage
        self.range += self.upgrade_range
        self.cooldown = max(10, self.cooldown - 3)
        self.name = self.level_name[self.level]
        return True

    def find_target(self, enemies):
        self.target = None
        best_progress = -1
        for enemy in enemies:
            if not enemy.alive:
                continue
            d = distance((self.x, self.y), (enemy.x, enemy.y))
            if d <= self.range:
                if enemy.path_progress > best_progress:
                    best_progress = enemy.path_progress
                    self.target = enemy
        if self.target:
            self.angle = math.degrees(math.atan2(
                self.target.y - self.y, self.target.x - self.x))

    def shoot(self):
        if not self.target or self.cooldown_timer > 0:
            return None
        if distance((self.x, self.y), (self.target.x, self.target.y)) > self.range:
            return None
        self.cooldown_timer = self.cooldown
        return Projectile(self.x, self.y, self.target, self.damage,
                          self.bullet_speed, self.bullet_color, self.effect)

    def update(self, enemies):
        if self.cooldown_timer > 0:
            self.cooldown_timer -= 1
        if not self.target or not self.target.alive:
            self.find_target(enemies)
        self.float_offset += 0.02

    def draw_range(self, screen):
        surface = pygame.Surface((self.range * 2, self.range * 2), pygame.SRCALPHA)
        pygame.draw.circle(surface, (*self.color, 30), (self.range, self.range), self.range)
        pygame.draw.circle(surface, (*self.color, 80), (self.range, self.range), self.range, 2)
        screen.blit(surface, (self.x - self.range, self.y - self.range))

    def draw(self, screen, frame=0):
        cx, cy = self.x, self.y

        # 绘制精灵图
        sprite = get_tower_sprite(self.type, self.level, size=32 + self.level * 3)
        if sprite:
            # 悬浮动画
            float_y = math.sin(self.float_offset) * 2
            sprite_rect = sprite.get_rect(center=(cx, cy - 5 + float_y))
            screen.blit(sprite, sprite_rect)
        else:
            # 降级绘制：简单几何图形
            size = GRID_SIZE // 2 - 4
            pygame.draw.rect(screen, COLOR_PATH,
                             (cx - size, cy - size, size * 2, size * 2), border_radius=5)
            pygame.draw.rect(screen, (80, 80, 80),
                             (cx - size, cy - size, size * 2, size * 2), 2, border_radius=5)

        # 等级标记
        if self.level > 1:
            lv_bg = pygame.Surface((16, 16), pygame.SRCALPHA)
            pygame.draw.circle(lv_bg, COLOR_GOLD, (8, 8), 8)
            screen.blit(lv_bg, (cx + 8, cy - 18))
            lv_text = FONT_TOWER.render(str(self.level), True, COLOR_BLACK)
            screen.blit(lv_text, (cx + 8 + 4, cy - 18 + 2))


