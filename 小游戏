# 子弹类
# ============================================================
class Projectile:
    def __init__(self, x, y, target, damage, speed, color, effect="normal"):
        self.x = x
        self.y = y
        self.target = target
        self.damage = damage
        self.speed = speed
        self.color = color
        self.effect = effect
        self.alive = True
        self.size = 5

    def update(self):
        if not self.target or not self.target.alive:
            self.alive = False
            return
        tx, ty = self.target.x, self.target.y
        dx, dy = tx - self.x, ty - self.y
        dist = math.sqrt(dx * dx + dy * dy)
        if dist < self.speed + 5:
            self.alive = False
            self.target.take_damage(self.damage)
            if self.effect == "ice":
                self.target.slow(0.5, 60)
            elif self.effect == "cannon":
                self.target.slow(0.3, 15)
            SOUND_HIT.play()
            return
        self.x += (dx / dist) * self.speed
        self.y += (dy / dist) * self.speed

    def draw(self, screen):
        pygame.draw.circle(screen, self.color, (int(self.x), int(self.y)), self.size)
        glow = pygame.Surface((self.size * 4, self.size * 4), pygame.SRCALPHA)
        pygame.draw.circle(glow, (*self.color, 80), (self.size * 2, self.size * 2), self.size * 2)
        screen.blit(glow, (int(self.x) - self.size * 2, int(self.y) - self.size * 2))


