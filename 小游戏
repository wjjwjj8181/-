# 音效生成器
# ============================================================
def generate_sound(frequency, duration, volume=0.4, sample_rate=22050,
                   wave_type="sine", freq_end=None, attack=0.01):
    """用数学函数生成音效，返回 pygame.mixer.Sound 对象"""
    n_samples = int(sample_rate * duration)
    buf = io.BytesIO()
    with wave.open(buf, 'w') as f:
        f.setnchannels(1)
        f.setsampwidth(2)
        f.setframerate(sample_rate)
        samples = []
        for i in range(n_samples):
            t = i / sample_rate
            progress = i / n_samples
            # ADSR-like envelope
            env_attack = min(1.0, t / attack) if attack > 0 else 1.0
            env_decay = max(0.0, 1.0 - progress ** 1.5)
            envelope = env_attack * env_decay * volume
            current_freq = frequency
            if freq_end:
                current_freq = frequency + (freq_end - frequency) * progress
            if wave_type == "square":
                val = 1.0 if math.sin(2 * math.pi * current_freq * t) > 0 else -1.0
            elif wave_type == "sawtooth":
                val = 2.0 * (current_freq * t % 1.0) - 1.0
            elif wave_type == "noise":
                val = random.uniform(-1.0, 1.0)
            else:  # sine
                val = math.sin(2 * math.pi * current_freq * t)
            sample = int(envelope * val * 32767)
            samples.append(struct.pack('<h', max(-32768, min(32767, sample))))
        f.writeframesraw(b''.join(samples))
    buf.seek(0)
    return pygame.mixer.Sound(buf)


